# Copy this file to .env.secrets and fill in real values.
# .env.secrets is gitignored — never commit it.
#
# After editing, run:
#   npm run sb:secrets
#
# These get pushed to Supabase as Edge Function secrets.

# Dodo Payments — get fresh values from the Dodo dashboard.
# If any of these have ever been pasted in chat, screenshots, docs, etc.,
# ROTATE them in Dodo before using. Once leaked, always leaked.
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_ENVIRONMENT=test_mode

# Product IDs from Dodo → Products page (these are not secrets, just refs).
DODO_PRODUCT_MONTHLY=
DODO_PRODUCT_QUARTERLY=
DODO_PRODUCT_LIFETIME=

# Where Dodo redirects after checkout. Switch to your prod domain at launch.
APP_URL=http://localhost:5173
