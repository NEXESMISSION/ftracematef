# Copy this file to .env.secrets and fill in real values.
# .env.secrets is gitignored — never commit it.
#
# After editing, run:
#   npm run sb:secrets
#
# These get pushed to Supabase as Edge Function secrets.

# Dodo Payments — get fresh values from the Dodo dashboard.
# If any of these have ever been pasted in chat, screenshots, docs, etc.,
# ROTATE them in Dodo before using. Once leaked, always leaked.
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_ENVIRONMENT=test_mode

# Product IDs from Dodo → Products page (these are not secrets, just refs).
DODO_PRODUCT_MONTHLY=
DODO_PRODUCT_QUARTERLY=
DODO_PRODUCT_LIFETIME=

# Per-(plan, currency) price floors — the dodo-webhook validates that
# incoming payment amounts meet or exceed these before granting entitlement.
# Without any floor set for a plan, payments for that plan FAIL CLOSED.
#
# Set one per (plan, currency) pair you actually accept on Dodo. To add a
# new region, just add the env var and redeploy — no code change needed.
# A currency with no configured floor for a plan is rejected.
DODO_PRICE_MONTHLY_CENTS_USD=500
DODO_PRICE_QUARTERLY_CENTS_USD=1000
DODO_PRICE_LIFETIME_CENTS_USD=1500
# Add EUR / GBP / etc as you need them:
# DODO_PRICE_MONTHLY_CENTS_EUR=449
# DODO_PRICE_QUARTERLY_CENTS_EUR=1199
# DODO_PRICE_LIFETIME_CENTS_EUR=1399

# Legacy (still honored, but prefer the per-currency vars above):
#   DODO_PRICE_<PLAN>_CENTS pairs with DODO_EXPECTED_CURRENCY (default USD)
#   when no DODO_PRICE_<PLAN>_CENTS_<CCY> is set for the plan.
# DODO_PRICE_MONTHLY_CENTS=500
# DODO_PRICE_QUARTERLY_CENTS=1000
# DODO_PRICE_LIFETIME_CENTS=1500
# DODO_EXPECTED_CURRENCY=USD

# Where Dodo redirects after checkout. Switch to your prod domain at launch.
APP_URL=http://localhost:5173

# OPTIONAL — comma-separated emails allowed to use the /account dev panel
# (calls dev-mutate-subscription). The frontend reads `profiles.is_admin`
# instead of an env var; grant the matching column with:
#   select public.set_admin_by_email('alice@example.com', true);
ADMIN_EMAILS=

# OPTIONAL — set to "true" ONLY in test/staging projects to enable the
# dev-mutate-subscription edge function. The function lets an admin flip
# their own subscription state without paying Dodo, so leaving it disabled
# in production is critical: an admin Google account compromise becomes a
# free-paid-plan exploit otherwise. Default-deny — anything other than the
# literal string "true" keeps the function returning 403.
ENABLE_DEV_MUTATE=

# REQUIRED for the super-analytics geo pipeline — a random secret used by the
# ingest-events function to salt+hash visitor IPs (the raw IP is NEVER stored).
# Generate once and keep stable (rotating it just resets the IP→geo cache):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ANALYTICS_IP_SALT=
