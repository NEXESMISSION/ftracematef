# OS / editor cruft
Thumbs.db
.idea
.vscode

# WebP test output (regeneratable, large)
public/_webp-test

# Local secrets file consumed by scripts/setup-supabase-secrets.mjs.
# The script itself is now safe to commit (reads from env / this file).
.env.secrets

# Safety net: keep .env.example out of git too, since it tends to get
# auto-filled with real values during local development.
# A safe template lives at .env.example.template instead.
.env.example

# Capacitor: regenerated from public/icon-* via `npm run cap:assets`.
assets/

# Capacitor production-config backups created during local APK testing.
capacitor.config.production.json
capacitor.config.local.json

# Native Android project — kept out of the web app repo. Regenerated locally
# via `npx cap add android`; the tree contains machine-specific Gradle /
# SDK paths and is large enough to bloat clones.
/android/

