/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The service worker must always revalidate so a new deploy's SW (and its fresh
# precache manifest) is picked up promptly. Never let it get pinned in an HTTP
# cache — a stale SW serving an old shell is how lazy routes break after a deploy.
/sw.js
  Cache-Control: no-cache

# Public images are unhashed and replaced by filename version (e.g. -v3).
# NOT immutable: if an edge ever caches a bad response (e.g. an SPA-fallback
# HTML body for an asset requested before it finished deploying), immutable
# would pin that for a year. A 1-day max-age + stale-while-revalidate keeps it
# fast while letting any bad entry self-heal within a day.
/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Demo reels (unhashed, large). Cache hard for fast repeat loads; SWR lets a
# replaced reel of the same name self-heal without pinning a bad entry.
/videos/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=2592000

